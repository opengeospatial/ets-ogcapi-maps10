<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="ogcapi-maps-1.0-${version}" verbose="0" configfailurepolicy="continue">
  <parameter name="iut" value="https://demo.pygeoapi.io/stable" />
  <parameter name="ics" value="" />
  <parameter name="noofcollections" value="5" />

  <listeners>
    <listener class-name="org.opengis.cite.ogcapimaps10.listener.TestRunListener" />
    <listener class-name="org.opengis.cite.ogcapimaps10.listener.SuiteFixtureListener" />
    <listener class-name="org.opengis.cite.ogcapimaps10.listener.TestFailureListener" />
    <listener class-name="org.opengis.cite.ogcapimaps10.listener.LoggingTestListener" />
  </listeners>

  <test name="Core">
   <classes>
     <class name="org.opengis.cite.ogcapimaps10.conformance.SuitePreconditions" />
     <class name="org.opengis.cite.ogcapimaps10.conformance.core.MapOperation" />
     <class name="org.opengis.cite.ogcapimaps10.conformance.core.MapResponse" />
     <class name="org.opengis.cite.ogcapimaps10.conformance.core.MapConformanceSuccess" />
   </classes>
  </test>

  <test name="Map Tilesets">
    <classes>
      <class name="org.opengis.cite.ogcapimaps10.conformance.mapTilesets.DescLinks" />
      <class name="org.opengis.cite.ogcapimaps10.conformance.mapTilesets.TilesParametersTest" />
    </classes>
  </test>

  <test name="Background">
    <classes>
      <class name="org.opengis.cite.ogcapimaps10.conformance.background.BgcolorParameterDefinition"/>
      <class name="org.opengis.cite.ogcapimaps10.conformance.background.TransparentParameterDefinition"/>
      <class name="org.opengis.cite.ogcapimaps10.conformance.background.VoidColorParameterDefinition"/>
      <class name="org.opengis.cite.ogcapimaps10.conformance.background.VoidTransparentParameterDefinition"/>
      <class name="org.opengis.cite.ogcapimaps10.conformance.background.BackgroundMapSuccess"/>
    </classes>
  </test>

  <test name="Dataset Map">
   <classes>
     <class name="org.opengis.cite.ogcapimaps10.conformance.datasetmap.DatasetMapLandingPage" />
   </classes>
  </test>

</suite>
