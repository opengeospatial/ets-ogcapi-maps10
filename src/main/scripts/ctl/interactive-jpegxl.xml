<?xml version="1.0" encoding="UTF-8"?>
<ctl:package xmlns:interactive-jpegxl="http://www.opengis.net/cite/ogcapi-maps-1.0/ctl/interactive-jpegxl.xml"
             xmlns:ctl="http://www.occamlab.com/ctl"
             xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
             xmlns:jxlitu="java:org.opengis.cite.ogcapimaps10.util.interactive.JpegXlInteractiveTestUtils">

  <!--
    Interactive test functions for JPEG XL content verification (Abstract test A.57).
    These functions display forms to collect manual verification results
    for requirements that cannot be automatically validated.
  -->

  <!-- Function 1: Verify JPEG XL is a color image representing geospatial features (Part B) -->
  <ctl:function name="interactive-jpegxl:verifyJpegXlColors">
    <ctl:param name="iut.url">The landing page URL of the implementation under test.</ctl:param>
    <ctl:return>The test result (true | false).</ctl:return>
    <ctl:description>
      Interactive test for JPEG XL content requirement Part B: Verify that the JPEG XL
      is a color image representing the geospatial features or coverage values in the map.
    </ctl:description>
    <ctl:code>
      <xsl:variable name="map-url-raw">
        <xsl:value-of select="jxlitu:buildMapRequestAsJpegXl($iut.url)" />
      </xsl:variable>
      <xsl:variable name="map-not-found" select="starts-with($map-url-raw, 'NOT_FOUND:')" />
      <xsl:variable name="map-url">
        <xsl:choose>
          <xsl:when test="$map-not-found">
            <xsl:value-of select="substring-after($map-url-raw, 'NOT_FOUND:')" />
          </xsl:when>
          <xsl:otherwise>
            <xsl:value-of select="$map-url-raw" />
          </xsl:otherwise>
        </xsl:choose>
      </xsl:variable>
      <xsl:variable name="form-values">
        <ctl:form width="900" height="700" xmlns="http://www.w3.org/1999/xhtml">
          <h3>JPEG XL Color Image Verification (Part B: /req/jpegxl/content)</h3>

          <div style="border: 1px solid #ccc; padding: 10px; margin: 10px 0; background: #f9f9f9;">
            <p><strong>Map Preview (JPEG XL):</strong></p>
            <p style="font-size: 0.9em; color: #666;">
              Note: JPEG XL (image/jxl) may not be natively supported by all browsers.
              If the image does not display, please use the link below to download and verify manually.
            </p>
            <xsl:element name="img">
              <xsl:attribute name="src"><xsl:value-of select="$map-url" /></xsl:attribute>
              <xsl:attribute name="alt">Map Preview (JPEG XL)</xsl:attribute>
              <xsl:attribute name="style">max-width: 600px; max-height: 500px; border: 1px solid #999;</xsl:attribute>
              <xsl:attribute name="onerror">this.style.display='none'; document.getElementById('jpegxl-color-error').style.display='block';</xsl:attribute>
              <xsl:attribute name="onload">document.getElementById('jpegxl-color-error').style.display='none';</xsl:attribute>
            </xsl:element>
            <div id="jpegxl-color-error" style="display: none; padding: 15px; background: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; color: #856404;">
              <p style="margin: 0 0 10px 0;"><strong>[!] Image cannot be displayed</strong></p>
              <p style="margin: 0; font-size: 0.9em;">Possible reasons:</p>
              <ul style="margin: 5px 0; font-size: 0.9em;">
                <li>Browser does not support JPEG XL format</li>
                <li>Server did not return JPEG XL format for this request</li>
                <li>Server returned an error response</li>
                <li>Invalid or inaccessible URL</li>
              </ul>
              <p style="margin: 10px 0 0 0; font-size: 0.9em;">Please click the link below to download and verify manually</p>
            </div>
          </div>

          <p><strong>Map URL:</strong></p>
          <p style="word-break: break-all;">
            <xsl:element name="a">
              <xsl:attribute name="href"><xsl:value-of select="$map-url" /></xsl:attribute>
              <xsl:attribute name="target">_blank</xsl:attribute>
              <xsl:value-of select="$map-url" />
            </xsl:element>
          </p>
          <xsl:if test="$map-not-found">
            <p style="color: #dc3545; font-size: 0.9em; margin-top: 5px;">[!] Warning: No valid map URL found. The service may not provide a [ogc-rel:map] link.</p>
          </xsl:if>

          <hr />
          <p style="margin-top: 20px;"><strong>Question:</strong> Is this JPEG XL a color image that correctly represents geospatial features or coverage values?</p>
          <p style="font-size: 0.9em; color: #666;">
            The map should display recognizable geographic content (e.g., land, water, roads, buildings)
            with colors that meaningfully correspond to the underlying data.
          </p>
          <p>
            <input type="submit" name="submit" value="yes" style="margin-right: 10px; padding: 5px 20px;" />
            <input type="submit" name="submit" value="no" style="padding: 5px 20px;" />
          </p>
        </ctl:form>
      </xsl:variable>
      <xsl:choose>
        <xsl:when test="$form-values/values/value[@key='submit']='yes'">
          <xsl:text>true</xsl:text>
        </xsl:when>
        <xsl:otherwise>
          <xsl:text>false</xsl:text>
        </xsl:otherwise>
      </xsl:choose>
    </ctl:code>
  </ctl:function>

  <!-- Function 2: Verify portrayal consistency across map requests (Part C) -->
  <ctl:function name="interactive-jpegxl:verifyPortrayalConsistency">
    <ctl:param name="iut.url">The landing page URL of the implementation under test.</ctl:param>
    <ctl:return>The test result (true | false).</ctl:return>
    <ctl:description>
      Interactive test for JPEG XL content requirement Part C: Verify that all maps
      representing parts of the same resource and using the same style follow
      the same portrayal rules.
    </ctl:description>
    <ctl:code>
      <xsl:variable name="map-url1-raw">
        <xsl:value-of select="jxlitu:buildMapRequestAsJpegXl($iut.url)" />
      </xsl:variable>
      <xsl:variable name="map-url2-raw">
        <xsl:value-of select="jxlitu:buildMapRequestWithBbox($iut.url, '-5,40,5,50')" />
      </xsl:variable>
      <xsl:variable name="map1-not-found" select="starts-with($map-url1-raw, 'NOT_FOUND:')" />
      <xsl:variable name="map-url1">
        <xsl:choose>
          <xsl:when test="$map1-not-found">
            <xsl:value-of select="substring-after($map-url1-raw, 'NOT_FOUND:')" />
          </xsl:when>
          <xsl:otherwise>
            <xsl:value-of select="$map-url1-raw" />
          </xsl:otherwise>
        </xsl:choose>
      </xsl:variable>
      <xsl:variable name="map2-not-found" select="starts-with($map-url2-raw, 'NOT_FOUND:')" />
      <xsl:variable name="map-url2">
        <xsl:choose>
          <xsl:when test="$map2-not-found">
            <xsl:value-of select="substring-after($map-url2-raw, 'NOT_FOUND:')" />
          </xsl:when>
          <xsl:otherwise>
            <xsl:value-of select="$map-url2-raw" />
          </xsl:otherwise>
        </xsl:choose>
      </xsl:variable>
      <xsl:variable name="form-values">
        <ctl:form width="1000" height="800" xmlns="http://www.w3.org/1999/xhtml">
          <h3>Portrayal Consistency Verification (Part C: /req/jpegxl/content)</h3>

          <p>Compare the two map images below. Both are from the <strong>same resource</strong> but show
             <strong>different areas</strong>. They should use the same rendering style (colors, symbols, line widths, etc.).</p>
          <p style="font-size: 0.9em; color: #666;">
            Note: JPEG XL (image/jxl) may not be natively supported by all browsers.
            If images do not display, please use the links below to download and verify manually.
          </p>

          <div style="display: flex; gap: 20px; flex-wrap: wrap;">
            <!-- Map 1: Default extent -->
            <div style="flex: 1; min-width: 300px; border: 1px solid #ccc; padding: 10px; background: #f9f9f9;">
              <p><strong>Map 1 (default extent):</strong></p>
              <xsl:element name="img">
                <xsl:attribute name="src"><xsl:value-of select="$map-url1" /></xsl:attribute>
                <xsl:attribute name="alt">Map 1 - Default Extent</xsl:attribute>
                <xsl:attribute name="style">max-width: 400px; max-height: 350px; border: 1px solid #999;</xsl:attribute>
                <xsl:attribute name="onerror">this.style.display='none'; document.getElementById('portrayal-error1').style.display='block';</xsl:attribute>
                <xsl:attribute name="onload">document.getElementById('portrayal-error1').style.display='none';</xsl:attribute>
              </xsl:element>
              <div id="portrayal-error1" style="display: none; padding: 10px; background: #fff3cd; border: 1px solid #ffc107; color: #856404;">
                <p style="margin: 0;"><strong>[!] Image cannot be displayed</strong></p>
              </div>
            </div>

            <!-- Map 2: Different extent (bbox) -->
            <div style="flex: 1; min-width: 300px; border: 1px solid #ccc; padding: 10px; background: #f9f9f9;">
              <p><strong>Map 2 (bbox: -5,40,5,50):</strong></p>
              <xsl:element name="img">
                <xsl:attribute name="src"><xsl:value-of select="$map-url2" /></xsl:attribute>
                <xsl:attribute name="alt">Map 2 - Subset Area</xsl:attribute>
                <xsl:attribute name="style">max-width: 400px; max-height: 350px; border: 1px solid #999;</xsl:attribute>
                <xsl:attribute name="onerror">this.style.display='none'; document.getElementById('portrayal-error2').style.display='block';</xsl:attribute>
                <xsl:attribute name="onload">document.getElementById('portrayal-error2').style.display='none';</xsl:attribute>
              </xsl:element>
              <div id="portrayal-error2" style="display: none; padding: 10px; background: #fff3cd; border: 1px solid #ffc107; color: #856404;">
                <p style="margin: 0;"><strong>[!] Image cannot be displayed</strong></p>
              </div>
            </div>
          </div>

          <xsl:if test="$map1-not-found or $map2-not-found">
            <p style="color: #dc3545; font-size: 0.9em; margin-top: 5px;">[!] Warning: No valid map URL found. The service may not provide a [ogc-rel:map] link.</p>
          </xsl:if>

          <hr />
          <p style="margin-top: 20px;"><strong>Question:</strong> Do both maps follow the same portrayal rules
             (consistent colors, symbols, and rendering style for the same features)?</p>
          <p>
            <input type="submit" name="submit" value="yes" style="margin-right: 10px; padding: 5px 20px;" />
            <input type="submit" name="submit" value="no" style="padding: 5px 20px;" />
          </p>
        </ctl:form>
      </xsl:variable>
      <xsl:choose>
        <xsl:when test="$form-values/values/value[@key='submit']='yes'">
          <xsl:text>true</xsl:text>
        </xsl:when>
        <xsl:otherwise>
          <xsl:text>false</xsl:text>
        </xsl:otherwise>
      </xsl:choose>
    </ctl:code>
  </ctl:function>

</ctl:package>
