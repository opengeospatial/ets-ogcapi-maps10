<?xml version="1.0" encoding="UTF-8"?>
<ctl:package xmlns:interactive="http://www.opengis.net/cite/ogcapi-maps-1.0/ctl/interactive-mm-per-pixel.xml"
             xmlns:ctl="http://www.occamlab.com/ctl"
             xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
             xmlns:dritu="java:org.opengis.cite.ogcapimaps10.util.interactive.DisplayResolutionInteractiveTestUtils">

  <!--
    Interactive test function for A.16 display-resolution verification (Req 16).

    Displays two map images side-by-side using a fixed scale-denominator and dimensions
    so that the server computes the bbox from those parameters (Effect 1):
      Map A - scale-denominator=40000000, width=1024, height=512, mm-per-pixel=0.28
      Map B - scale-denominator=40000000, width=1024, height=512, mm-per-pixel=0.14

    Halving mm-per-pixel from 0.28 to 0.14 halves the physical pixel size, which halves
    the computed bbox extent at the same scale. Map B should therefore show a zoomed-in
    view covering half the area of Map A.

    Asks the user to confirm that the two maps look visually different (different spatial
    extents / zoom levels), which verifies that the server correctly interprets mm-per-pixel.
  -->

  <ctl:function name="interactive:verifyMmPerPixelInterpretation">
    <ctl:param name="iut.url">The API landing page URL.</ctl:param>
    <ctl:return>The test result: "true" if the user confirmed the maps look different, "false" otherwise.</ctl:return>
    <ctl:description>
      Interactive test for A.16 (Req 16): Verify that the server correctly interprets
      the mm-per-pixel parameter by rendering maps at different display resolutions.
    </ctl:description>
    <ctl:code>

      <!-- Build Map A: mm-per-pixel=0.28 (default, standard screen) -->
      <xsl:variable name="map-a-raw">
        <xsl:value-of select="dritu:buildDefaultResolutionMapUrl($iut.url)" />
      </xsl:variable>

      <!-- Build Map B: mm-per-pixel=0.1 (high-DPI, more detail expected) -->
      <xsl:variable name="map-b-raw">
        <xsl:value-of select="dritu:buildHighDpiMapUrl($iut.url)" />
      </xsl:variable>

      <!-- Detect NOT_FOUND sentinel -->
      <xsl:variable name="not-found" select="starts-with($map-a-raw, 'NOT_FOUND:')" />

      <xsl:variable name="map-a-url">
        <xsl:choose>
          <xsl:when test="$not-found">
            <xsl:value-of select="substring-after($map-a-raw, 'NOT_FOUND:')" />
          </xsl:when>
          <xsl:otherwise><xsl:value-of select="$map-a-raw" /></xsl:otherwise>
        </xsl:choose>
      </xsl:variable>

      <xsl:variable name="map-b-url">
        <xsl:choose>
          <xsl:when test="starts-with($map-b-raw, 'NOT_FOUND:')">
            <xsl:value-of select="substring-after($map-b-raw, 'NOT_FOUND:')" />
          </xsl:when>
          <xsl:otherwise><xsl:value-of select="$map-b-raw" /></xsl:otherwise>
        </xsl:choose>
      </xsl:variable>

      <!-- Show form and collect user answer -->
      <xsl:variable name="form-values">
        <ctl:form width="1000" height="820" xmlns="http://www.w3.org/1999/xhtml">
          <h3>Display Resolution Verification (A.16 - Req 16)</h3>
          <p>
            Two maps have been requested using different <strong>mm-per-pixel</strong> values.
            A smaller mm-per-pixel means each pixel is physically smaller, so the server
            should render finer detail (more roads, smaller labels, denser symbology).
          </p>
          <table style="width:100%; font-size:0.9em; background:#f0f0f0;
                        border:1px solid #ccc; padding:6px; margin-bottom:10px;">
            <tr>
              <td style="width:50%; padding:4px;"><strong>Map A</strong> - scale-denominator=40000000, width=1024, height=512, mm-per-pixel=0.28</td>
              <td style="width:50%; padding:4px;"><strong>Map B</strong> - scale-denominator=40000000, width=1024, height=512, mm-per-pixel=0.14</td>
            </tr>
          </table>

          <xsl:if test="$not-found">
            <p style="color:#dc3545; background:#fff3cd; border:1px solid #ffc107; padding:8px;">
              [!] Warning: Could not discover a dataset map endpoint automatically.
              The URLs below may not be valid. Please verify manually.
            </p>
          </xsl:if>

          <!-- Side-by-side map previews -->
          <table style="width:100%; border-collapse:collapse;">
            <tr>
              <!-- Map A: mm-per-pixel=0.28 with scale-denominator -->
              <td style="width:50%; padding:8px; vertical-align:top;">
                <p><strong>Map A</strong> - mm-per-pixel=0.28 (scale-denominator=40000000, 1024x512)</p>
                <p style="font-size:0.85em; word-break:break-all;">
                  <xsl:element name="a">
                    <xsl:attribute name="href"><xsl:value-of select="$map-a-url" /></xsl:attribute>
                    <xsl:attribute name="target">_blank</xsl:attribute>
                    <xsl:value-of select="$map-a-url" />
                  </xsl:element>
                </p>
                <div style="border:1px solid #ccc; padding:4px; background:#f9f9f9; min-height:200px;">
                  <xsl:element name="img">
                    <xsl:attribute name="src"><xsl:value-of select="$map-a-url" /></xsl:attribute>
                    <xsl:attribute name="alt">Map A - standard resolution</xsl:attribute>
                    <xsl:attribute name="style">max-width:100%; border:1px solid #999;</xsl:attribute>
                    <xsl:attribute name="onerror">this.style.display='none';document.getElementById('map-a-error').style.display='block';</xsl:attribute>
                  </xsl:element>
                  <div id="map-a-error" style="display:none; color:#856404; background:#fff3cd;
                                               border:1px solid #ffc107; padding:8px; font-size:0.85em;">
                    Image cannot be displayed. Open the link above in a new tab.
                  </div>
                </div>
              </td>

              <!-- Map B: mm-per-pixel=0.14 with scale-denominator (zoomed in) -->
              <td style="width:50%; padding:8px; vertical-align:top;">
                <p><strong>Map B</strong> - mm-per-pixel=0.14 (scale-denominator=40000000, 1024x512)</p>
                <p style="font-size:0.85em; word-break:break-all;">
                  <xsl:element name="a">
                    <xsl:attribute name="href"><xsl:value-of select="$map-b-url" /></xsl:attribute>
                    <xsl:attribute name="target">_blank</xsl:attribute>
                    <xsl:value-of select="$map-b-url" />
                  </xsl:element>
                </p>
                <div style="border:1px solid #ccc; padding:4px; background:#f9f9f9; min-height:200px;">
                  <xsl:element name="img">
                    <xsl:attribute name="src"><xsl:value-of select="$map-b-url" /></xsl:attribute>
                    <xsl:attribute name="alt">Map B - high-DPI resolution</xsl:attribute>
                    <xsl:attribute name="style">max-width:100%; border:1px solid #999;</xsl:attribute>
                    <xsl:attribute name="onerror">this.style.display='none';document.getElementById('map-b-error').style.display='block';</xsl:attribute>
                  </xsl:element>
                  <div id="map-b-error" style="display:none; color:#856404; background:#fff3cd;
                                               border:1px solid #ffc107; padding:8px; font-size:0.85em;">
                    Image cannot be displayed. Open the link above in a new tab.
                  </div>
                </div>
              </td>
            </tr>
          </table>

          <hr style="margin-top:16px;" />
          <p style="margin-top:16px;">
            <strong>Question:</strong> Do Map A and Map B look <strong>visually different</strong>?
            (Map B uses mm-per-pixel=0.14, half of Map A's 0.28. At the same scale-denominator
            and dimensions, Map B should cover half the spatial extent of Map A - appearing
            zoomed in to a smaller area.)
          </p>
          <p>
            <input type="submit" name="submit" value="yes"
                   style="margin-right:12px; padding:6px 24px;" />
            <input type="submit" name="submit" value="no"
                   style="padding:6px 24px;" />
          </p>
        </ctl:form>
      </xsl:variable>

      <!-- Return true/false based on user answer -->
      <xsl:choose>
        <xsl:when test="$form-values/values/value[@key='submit'] = 'yes'">
          <xsl:text>true</xsl:text>
        </xsl:when>
        <xsl:otherwise>
          <xsl:text>false</xsl:text>
        </xsl:otherwise>
      </xsl:choose>

    </ctl:code>
  </ctl:function>


  <!--
    Interactive test function for A.16 default assumption verification (Req 16).

    Displays two map images side-by-side:
      Map A - no mm-per-pixel parameter (server should use its default of 0.28)
      Map B - mm-per-pixel=0.28 (explicit standard resolution)

    Asks the user to confirm that the two maps look visually the same,
    which verifies that the server correctly assumes 0.28 mm/pixel when
    the parameter is omitted.
  -->

  <ctl:function name="interactive:verifyMmPerPixelDefault">
    <ctl:param name="iut.url">The API landing page URL.</ctl:param>
    <ctl:return>The test result: "true" if the user confirmed the maps look the same, "false" otherwise.</ctl:return>
    <ctl:description>
      Interactive test for A.16 (Req 16): Verify that the server assumes 0.28 mm/pixel
      when the mm-per-pixel parameter is omitted.
    </ctl:description>
    <ctl:code>

      <!-- Map A: no mm-per-pixel parameter (relies on server default) -->
      <xsl:variable name="map-a-raw">
        <xsl:value-of select="dritu:buildNoParamMapUrl($iut.url)" />
      </xsl:variable>

      <!-- Map B: mm-per-pixel=0.28 (explicit standard resolution) -->
      <xsl:variable name="map-b-raw">
        <xsl:value-of select="dritu:buildDefaultResolutionMapUrl($iut.url)" />
      </xsl:variable>

      <!-- Detect NOT_FOUND sentinel -->
      <xsl:variable name="not-found" select="starts-with($map-a-raw, 'NOT_FOUND:')" />

      <xsl:variable name="map-a-url">
        <xsl:choose>
          <xsl:when test="$not-found">
            <xsl:value-of select="substring-after($map-a-raw, 'NOT_FOUND:')" />
          </xsl:when>
          <xsl:otherwise><xsl:value-of select="$map-a-raw" /></xsl:otherwise>
        </xsl:choose>
      </xsl:variable>

      <xsl:variable name="map-b-url">
        <xsl:choose>
          <xsl:when test="starts-with($map-b-raw, 'NOT_FOUND:')">
            <xsl:value-of select="substring-after($map-b-raw, 'NOT_FOUND:')" />
          </xsl:when>
          <xsl:otherwise><xsl:value-of select="$map-b-raw" /></xsl:otherwise>
        </xsl:choose>
      </xsl:variable>

      <!-- Show form and collect user answer -->
      <xsl:variable name="form-values">
        <ctl:form width="1000" height="820" xmlns="http://www.w3.org/1999/xhtml">
          <h3>Display Resolution Default Assumption Verification (A.16 - Req 16)</h3>
          <p>
            Two maps have been requested. Map A omits <strong>mm-per-pixel</strong> entirely,
            so the server should use its default of 0.28 mm/pixel. Map B requests
            <strong>mm-per-pixel=0.28</strong> explicitly. Both maps should look identical
            if the server correctly assumes 0.28 as the default.
          </p>
          <table style="width:100%; font-size:0.9em; background:#f0f0f0;
                        border:1px solid #ccc; padding:6px; margin-bottom:10px;">
            <tr>
              <td style="width:50%; padding:4px;"><strong>Map A</strong> - scale-denominator=40000000, width=1024, height=512, no mm-per-pixel</td>
              <td style="width:50%; padding:4px;"><strong>Map B</strong> - scale-denominator=40000000, width=1024, height=512, mm-per-pixel=0.28</td>
            </tr>
          </table>

          <xsl:if test="$not-found">
            <p style="color:#dc3545; background:#fff3cd; border:1px solid #ffc107; padding:8px;">
              [!] Warning: Could not discover a dataset map endpoint automatically.
              The URLs below may not be valid. Please verify manually.
            </p>
          </xsl:if>

          <!-- Side-by-side map previews -->
          <table style="width:100%; border-collapse:collapse;">
            <tr>
              <!-- Map A: no mm-per-pixel -->
              <td style="width:50%; padding:8px; vertical-align:top;">
                <p><strong>Map A</strong> - no mm-per-pixel (server default, scale-denominator=40000000, 1024x512)</p>
                <p style="font-size:0.85em; word-break:break-all;">
                  <xsl:element name="a">
                    <xsl:attribute name="href"><xsl:value-of select="$map-a-url" /></xsl:attribute>
                    <xsl:attribute name="target">_blank</xsl:attribute>
                    <xsl:value-of select="$map-a-url" />
                  </xsl:element>
                </p>
                <div style="border:1px solid #ccc; padding:4px; background:#f9f9f9; min-height:200px;">
                  <xsl:element name="img">
                    <xsl:attribute name="src"><xsl:value-of select="$map-a-url" /></xsl:attribute>
                    <xsl:attribute name="alt">Map A - no mm-per-pixel parameter</xsl:attribute>
                    <xsl:attribute name="style">max-width:100%; border:1px solid #999;</xsl:attribute>
                    <xsl:attribute name="onerror">this.style.display='none';document.getElementById('def-map-a-error').style.display='block';</xsl:attribute>
                  </xsl:element>
                  <div id="def-map-a-error" style="display:none; color:#856404; background:#fff3cd;
                                                   border:1px solid #ffc107; padding:8px; font-size:0.85em;">
                    Image cannot be displayed. Open the link above in a new tab.
                  </div>
                </div>
              </td>

              <!-- Map B: mm-per-pixel=0.28 -->
              <td style="width:50%; padding:8px; vertical-align:top;">
                <p><strong>Map B</strong> - mm-per-pixel=0.28 (explicit, scale-denominator=40000000, 1024x512)</p>
                <p style="font-size:0.85em; word-break:break-all;">
                  <xsl:element name="a">
                    <xsl:attribute name="href"><xsl:value-of select="$map-b-url" /></xsl:attribute>
                    <xsl:attribute name="target">_blank</xsl:attribute>
                    <xsl:value-of select="$map-b-url" />
                  </xsl:element>
                </p>
                <div style="border:1px solid #ccc; padding:4px; background:#f9f9f9; min-height:200px;">
                  <xsl:element name="img">
                    <xsl:attribute name="src"><xsl:value-of select="$map-b-url" /></xsl:attribute>
                    <xsl:attribute name="alt">Map B - mm-per-pixel=0.28</xsl:attribute>
                    <xsl:attribute name="style">max-width:100%; border:1px solid #999;</xsl:attribute>
                    <xsl:attribute name="onerror">this.style.display='none';document.getElementById('def-map-b-error').style.display='block';</xsl:attribute>
                  </xsl:element>
                  <div id="def-map-b-error" style="display:none; color:#856404; background:#fff3cd;
                                                   border:1px solid #ffc107; padding:8px; font-size:0.85em;">
                    Image cannot be displayed. Open the link above in a new tab.
                  </div>
                </div>
              </td>
            </tr>
          </table>

          <hr style="margin-top:16px;" />
          <p style="margin-top:16px;">
            <strong>Question:</strong> Do Map A and Map B look <strong>visually the same</strong>?
            (If the server assumes 0.28 mm/pixel by default, both maps should be identical.)
          </p>
          <p>
            <input type="submit" name="submit" value="yes"
                   style="margin-right:12px; padding:6px 24px;" />
            <input type="submit" name="submit" value="no"
                   style="padding:6px 24px;" />
          </p>
        </ctl:form>
      </xsl:variable>

      <!-- Return true/false based on user answer -->
      <xsl:choose>
        <xsl:when test="$form-values/values/value[@key='submit'] = 'yes'">
          <xsl:text>true</xsl:text>
        </xsl:when>
        <xsl:otherwise>
          <xsl:text>false</xsl:text>
        </xsl:otherwise>
      </xsl:choose>

    </ctl:code>
  </ctl:function>

</ctl:package>
