<?xml version="1.0" encoding="UTF-8"?>
<ctl:package xmlns:interactive="http://www.opengis.net/cite/ogcapi-maps-1.0/ctl/interactive.xml"
             xmlns:ctl="http://www.occamlab.com/ctl"
             xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
             xmlns:itu="java:org.opengis.cite.ogcapimaps10.util.interactive.InteractiveTestUtils">

  <!--
    Interactive test functions for tiles-parameters verification.
    These functions display forms to collect manual verification results
    for parameters that cannot be automatically validated.
  -->

  <!-- Function 1: Verify bgcolor parameter on tiles -->
  <ctl:function name="interactive:verifyTilesBgcolor">
    <ctl:param name="tiles.url">The tiles endpoint URL.</ctl:param>
    <ctl:param name="bgcolor">The expected background color value.</ctl:param>
    <ctl:param name="tileMatrixSet">The TileMatrixSet identifier.</ctl:param>
    <ctl:return>The test result (true | false).</ctl:return>
    <ctl:description>
      Interactive test for tiles-parameters requirement: Verify that the bgcolor
      parameter is correctly applied to map tiles.
    </ctl:description>
    <ctl:code>
      <xsl:variable name="tile-url-raw">
        <xsl:value-of select="itu:buildTileRequestWithBgcolor($tiles.url, $bgcolor, $tileMatrixSet)" />
      </xsl:variable>
      <xsl:variable name="tile-not-found" select="starts-with($tile-url-raw, 'NOT_FOUND:')" />
      <xsl:variable name="tile-url">
        <xsl:choose>
          <xsl:when test="$tile-not-found">
            <xsl:value-of select="substring-after($tile-url-raw, 'NOT_FOUND:')" />
          </xsl:when>
          <xsl:otherwise>
            <xsl:value-of select="$tile-url-raw" />
          </xsl:otherwise>
        </xsl:choose>
      </xsl:variable>
      <xsl:variable name="form-values">
        <ctl:form width="900" height="700" xmlns="http://www.w3.org/1999/xhtml">
          <h3>Background Color Verification (bgcolor parameter)</h3>

          <div style="border: 1px solid #ccc; padding: 10px; margin: 10px 0; background: #f9f9f9;">
            <p><strong>Tile Preview:</strong></p>
            <xsl:element name="img">
              <xsl:attribute name="src"><xsl:value-of select="$tile-url" /></xsl:attribute>
              <xsl:attribute name="alt">Tile Preview</xsl:attribute>
              <xsl:attribute name="style">max-width: 512px; max-height: 512px; border: 1px solid #999;</xsl:attribute>
              <xsl:attribute name="onerror">this.style.display='none'; document.getElementById('bgcolor-error').style.display='block';</xsl:attribute>
              <xsl:attribute name="onload">document.getElementById('bgcolor-error').style.display='none';</xsl:attribute>
            </xsl:element>
            <div id="bgcolor-error" style="display: none; padding: 15px; background: #fff3cd; border: 1px solid #ffc107; border-radius: 4px; color: #856404;">
              <p style="margin: 0 0 10px 0;"><strong>[!] Image cannot be displayed</strong></p>
              <p style="margin: 0; font-size: 0.9em;">Possible reasons:</p>
              <ul style="margin: 5px 0; font-size: 0.9em;">
                <li>Image format not supported by browser (e.g., TIFF, MVT vector tiles)</li>
                <li>Server returned an error response</li>
                <li>Invalid or inaccessible URL</li>
              </ul>
              <p style="margin: 10px 0 0 0; font-size: 0.9em;">Please click the link below to open in a new tab for details</p>
            </div>
          </div>

          <p><strong>Tile URL:</strong></p>
          <p style="word-break: break-all;">
            <xsl:element name="a">
              <xsl:attribute name="href"><xsl:value-of select="$tile-url" /></xsl:attribute>
              <xsl:attribute name="target">_blank</xsl:attribute>
              <xsl:value-of select="$tile-url" />
            </xsl:element>
          </p>
          <xsl:if test="$tile-not-found">
            <p style="color: #dc3545; font-size: 0.9em; margin-top: 5px;">[!] Warning: No valid tile URL found. The service may not support Map Tilesets (tilesets-map).</p>
          </xsl:if>

          <p><strong>Parameter used:</strong> bgcolor=<code><xsl:value-of select="$bgcolor" /></code></p>

          <hr />
          <p style="margin-top: 20px;"><strong>Question:</strong> Does the tile display the correct background color?</p>
          <p>
            <input type="submit" name="submit" value="yes" style="margin-right: 10px; padding: 5px 20px;" />
            <input type="submit" name="submit" value="no" style="padding: 5px 20px;" />
          </p>
        </ctl:form>
      </xsl:variable>
      <xsl:choose>
        <xsl:when test="$form-values/values/value[@key='submit']='yes'">
          <xsl:text>true</xsl:text>
        </xsl:when>
        <xsl:otherwise>
          <xsl:text>false</xsl:text>
        </xsl:otherwise>
      </xsl:choose>
    </ctl:code>
  </ctl:function>

